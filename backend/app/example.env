# ============================================================================
# LLM Configuration
# ============================================================================

# Active Provider
# Options: openai | groq | ollama
LLM_PROVIDER=groq

# ============================================================================
# OpenAI
# ============================================================================

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================================
# Groq
# ============================================================================

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ============================================================================
# Ollama
# ============================================================================

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ============================================================================
# Generation Parameters
# ============================================================================

TEMPERATURE=0.7
MAX_TOKENS=1024
TOP_P=1.0
LLM_STREAM=false

# ============================================================================
# Request Settings
# ============================================================================

LLM_REQUEST_TIMEOUT=30
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_DELAY=2

# ============================================================================
# Embedding Model
# ============================================================================

EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ============================================================================
# Logging
# ============================================================================

LOG_LEVEL=INFO

# ============================================================================
# Email
# ============================================================================

MY_EMAIL=
APP_PASSWORD=

# ============================================================================
# Database
# ============================================================================

DB_BACKEND=postgres

DATABASE_URL=postgresql://postgres:REMEMBER@localhost:5432/ai_news

POSTGRES_USER=postgres
POSTGRES_PASSWORD=REMEMBER
POSTGRES_DB=ai_news
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ============================================================================
# Feed
# ============================================================================

AUTO_REFRESH_ON_EMPTY=true