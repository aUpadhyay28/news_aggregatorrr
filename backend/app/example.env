# ---------------------------------------------------------------------------
# LLM provider configuration
# ---------------------------------------------------------------------------
# Which provider to prefer: openai | groq | ollama
# The app always builds a resilient fallback chain around this preference:
#   <LLM_PROVIDER> -> groq -> openai -> ollama -> rule-based (never fails)
LLM_PROVIDER=groq

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Shared generation parameters (used by whichever provider is active)
TEMPERATURE=0.7
MAX_TOKENS=1024
TOP_P=1.0
LLM_REQUEST_TIMEOUT=30

# ---------------------------------------------------------------------------
# Email
# ---------------------------------------------------------------------------
MY_EMAIL=
APP_PASSWORD=

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DB_BACKEND=postgres
DATABASE_URL=postgresql://postgres:REMEMBER@localhost:5432/ai_news

POSTGRES_USER=postgres
POSTGRES_PASSWORD=REMEMBER
POSTGRES_DB=ai_news
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
